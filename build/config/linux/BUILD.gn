# Linux specific configs

import("//build/config/args.gni")

config("linux_config") {
  defines = []
  cflags = []
  ldflags = []

  # Assume Unicode on Linux
  defines += [
    "UNICODE",
    "_UNICODE",
  ]
  cflags += [
    "-finput-charset=UTF-8",
    "-fexec-charset=UTF-8",
  ]

  if (is_debug) {
    cflags += [
      "-Og",
      "-g2",
    ]
    if (use_dwarf) {
      cflags += [ "-gdwarf-2" ]
    }
  } else {
    if (is_official_build) {
      cflags += [
        "-O3",
        "-g0",
      ]
      # Strip binaries
      cflags += [ "-s", ]
      ldflags += [ "-s", ]
    } else {
      cflags += [
        "-O1",
        "-g1",
      ]
    }
  }

  # PIC for PIE
  cflags += [
    "-fPIC",
  ]
  ldflags += [
    "-fpic",
  ]

  # Default to using threads
  cflags += [ "-pthread", ]

  # Defalt linux system libraries
  libs = [
    "m",
  ]
}
